{
  "compilerOptions": {
    "composite": true,
    "target": "ES2020",
    "lib": ["ES2020"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowSyntheticDefaultImports": true,
    "tsBuildInfoFile": ".build/tsconfig.node.tsbuildinfo",
    "outDir": ".build/tsconfig-node",
    "types": ["node"]
  },
  "include": ["vite.config.ts"]
}
