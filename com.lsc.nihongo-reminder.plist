<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.lsc.nihongo-reminder</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/zsh</string>
    <string>-lc</string>
    <string>cd "/Users/lsc/Documents/New project" &amp;&amp; /opt/homebrew/opt/python@3.14/bin/python3.14 remind.py</string>
  </array>

  <key>StartCalendarInterval</key>
  <dict>
    <key>Hour</key>
    <integer>23</integer>
    <key>Minute</key>
    <integer>30</integer>
  </dict>

  <key>StandardOutPath</key>
  <string>/Users/lsc/Documents/New project/reminder.v2.log</string>

  <key>StandardErrorPath</key>
  <string>/Users/lsc/Documents/New project/reminder.v2.err.log</string>
</dict>
</plist>
